#!/usr/bin/env bash
# Show the last saved verdict in full, then wait. Launched by the tray's
# "Details" button (and by the notification body click for non-safe verdicts).
set -u
CHECK="$(dirname "$0")/twsu-check"
[ -x "$CHECK" ] || CHECK="twsu-check"

"$CHECK" --pretty --cached --list
echo
echo "Tip: run '$CHECK --pretty' to re-check now (refreshes repos),"
echo "     or click 'Update now' from the tray icon to install."
echo
read -rp "Press Enter to close this window…"
