#!/usr/bin/env bash
# tw-safe-update: interactive terminal wrapper around the real `zypper dup`.
# Launched by the tray in a terminal; the real update intentionally asks for
# your password (only the read-only dry-run checks are passwordless).
set -u

# Resolve the checker next to this script (works for both the /usr/bin package
# and a ~/.local/bin dev install), falling back to PATH.
CHECK="$(dirname "$0")/twsu-check"
[ -x "$CHECK" ] || CHECK="twsu-check"

BOLD=$'\e[1m'; GREEN=$'\e[32m'; RED=$'\e[31m'; RESET=$'\e[0m'

echo "${BOLD}════ TW Safe Update — distribution upgrade ════${RESET}"
echo "Running the real ${BOLD}zypper dist-upgrade${RESET} now."
echo "You will be asked for your password — review the summary before confirming."
echo

sudo /usr/bin/zypper dist-upgrade
rc=$?

echo
if [ $rc -eq 0 ]; then
    echo "${GREEN}${BOLD}Update finished successfully.${RESET}"
elif [ $rc -eq 102 ]; then
    echo "${GREEN}${BOLD}Update finished — a REBOOT is required.${RESET}"
else
    echo "${RED}${BOLD}zypper exited with code $rc${RESET}"
fi

echo
echo "Re-checking system status…"
"$CHECK" --pretty --no-refresh || true

echo
read -rp "Press Enter to close this window…"
exit $rc
